{
  "id": "reinoMagico",
  "name": "Reino Mágico",
  "description": "Un mundo encantado lleno de magia y fantasía",
  "version": "1.0.0",
  "author": "Video Diario",
  "free": false,
  "theme": {
    "tokens": {
      "--color-primary": "270 60% 50%",
      "--color-secondary": "300 40% 90%",
      "--color-accent": "330 70% 60%",
      "--color-background": "270 20% 98%",
      "--color-foreground": "270 50% 10%",
      "--color-glow": "270 80% 70%"
    }
  },
  "stickers": {
    "autoLoad": true,
    "folder": "stickers",
    "categories": [
      {
        "id": "default",
        "name": "Principales",
        "items": [
          "stickers/estrella.png",
          "stickers/corona.png",
          "stickers/varita.png",
          "stickers/unicornio.png"
        ]
      }
    ]
  },
  "frames": {
    "autoLoad": true,
    "folder": "frames",
    "items": [
      { "key": "castillo-magico", "file": "frames/castillo.png" },
      { "key": "marco-estrellas", "file": "frames/marco-estrellas.png" }
    ]
  },
  "sounds": [
    { "key": "shutter", "file": "sounds/shutter.mp3", "type": "effect" },
    { "key": "magic", "file": "sounds/magic.mp3", "type": "ambience" }
  ],
  "soundsAuto": {
    "autoLoad": true,
    "folder": "sounds",
    "defaultType": "effect"
  },
  "intro": "intro/intro.mp4",
  "preview": {
    "cover": "preview/preview.png",
    "accent": "var(--color-accent)"
  }
}
